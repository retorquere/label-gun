{
  "name": "label-gun",
  "version": "4.0.11",
  "private": true,
  "description": "automatic issue labeler",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run package",
    "format-check": "prettier --check **/*.ts",
    "lint": "dprint fmt src/*.ts && dprint check src/*.ts",
    "package": "./esbuild.js && npm run lint && tsc --noEmit",
    "preversion": "npm start && git add -u",
    "postversion": "git push --follow-tags",
    "test": "echo test",
    "start": "npm run build && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/request-error": "^7.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dprint": "^0.54.0",
    "esbuild": "^0.28.0",
    "object-dot-parser": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
